# ── Required ────────────────────────────────────────────────────────────────

# Google Gemini — image-to-level vision pipeline
GEMINI_API_KEY=

# Anthropic — Claude Haiku hard-mode level remixer
ANTHROPIC_API_KEY=

# ── Optional ────────────────────────────────────────────────────────────────

# K2 Think V2 — solvability verification (streaming reasoning panel)
K2_API_KEY=
K2_API_BASE_URL=https://api.k2think.ai/v1

# Override the default AI model for hard mode (default: claude-haiku-4-5-20251001)
# LLM_MODEL=

# ── Server ──────────────────────────────────────────────────────────────────

# CORS — set to your Vercel frontend URL in production
FRONTEND_URL=http://localhost:5173

# Port (Render sets this automatically; leave as 3000 for local dev)
PORT=3000
