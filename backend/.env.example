# Google Gemini — image-to-level vision pipeline
GEMINI_API_KEY=

# K2 Think — solvability verification (streaming reasoning)
K2_API_KEY=
K2_API_BASE_URL=https://api.k2think.ai/v1

# Anthropic — Claude Haiku fallback for hard mode
ANTHROPIC_API_KEY=

# CORS — set to your Vercel frontend URL in production
FRONTEND_URL=https://your-frontend.vercel.app

# Server port (Render sets this automatically)
PORT=3000
